# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-in-production-generate-with-openssl-rand-hex-32

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://interviewcraft:interviewcraft@localhost:5432/interviewcraft

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
# Scoring calibrated to Claude Sonnet — warn if swapping models
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE  # Generate at https://console.anthropic.com/settings/keys

# ── Deepgram (STT streaming + Budget TTS via Deepgram Aura-1) ─────────────────
# Pricing: Nova-2 STT $0.0058/min | Aura-1 TTS $0.015/1K chars
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE  # Generate at https://console.deepgram.com

# ── ElevenLabs (Quality TTS) ──────────────────────────────────────────────────
# Pricing: Turbo v2.5 $0.06/1K chars
ELEVENLABS_API_KEY=sk_YOUR_KEY_HERE  # Generate at https://elevenlabs.io/app/settings/api-keys

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth (optional — can be left blank in dev) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (leave blank to disable digest emails) ────────────────────────
# Works with any SMTP provider: Gmail, SendGrid, Resend, Postmark, Mailgun, etc.
# Gmail: smtp.gmail.com:587, use an App Password (not your account password)
# Resend: smtp.resend.com:587, username=resend, password=your_resend_api_key
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@interviewcraft.app
SMTP_FROM_NAME=InterviewCraft
SMTP_TLS=true

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
